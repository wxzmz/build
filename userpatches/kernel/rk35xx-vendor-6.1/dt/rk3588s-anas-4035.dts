&u2phy3 {
	status = "okay";
};

&u2phy3_host {
	//phy-supply = <&vcc5v0_host>;
	status = "okay";
};

&usb_host0_ehci {
	status = "okay";
};

&usb_host0_ohci {
	status = "okay";
};

&usb_host1_ehci {
	status = "okay";
};

&usb_host1_ohci {
	status = "okay";
};

&usbdrd3_0 {
	status = "okay";
};

&usbdrd_dwc3_0 {
	status = "okay";
	dr_mode = "host";
	//extcon = <&u2phy0>;
	vbus-supply = <&vcc5v0_otg>;
	snps,parkmode-disable-hs-quirk;
	snps,parkmode-disable-ss-quirk;
};

&usbhost3_0 {
	status = "disabled";
};

&usbhost_dwc3_0 {
	status = "disabled";
};

&usbdp_phy0 {
	status = "okay";
	rockchip,dp-lane-mux = <0 1>;
};

&usbdp_phy0_dp {
	status = "okay";
};

&usbdp_phy0_u3 {
	status = "okay";
};



&hdmi0 {
	status = "okay";
