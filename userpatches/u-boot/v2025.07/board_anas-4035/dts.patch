+		pwr_led: pwr-led {
+			label = "pwr_led";
+			gpios = <&gpio3 RK_PC4 GPIO_ACTIVE_HIGH>;
+			default-state = "on";
+			pinctrl-names = "default";
+			pinctrl-0 = <&pwr_led_pin>;
+		};
+
+
+	};
+
+	vcc12v_dcin: regulator-vcc12v-dcin {
+		compatible = "regulator-fixed";
+		regulator-name = "vcc12v_dcin";
+		regulator-always-on;
